const fetchGetPosts = () => {
  let posts = [];
  fetch('http://localhost:7070/posts')
    .then(response => {
      if (!response.ok) {
        throw new Error(`HTTP error! Status: ${response.status}`);
      }
        return response.json();
    })
    .then(data => {
      console.log(data);
      posts = data;
    })
    .catch(error => {
      console.error('!!! FetchPosts error:', error);
    });
  return posts;
}

export default fetchGetPosts;